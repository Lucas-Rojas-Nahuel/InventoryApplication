<!DOCTYPE html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title%></title>
    <link rel="stylesheet" href="/styles/output.css" />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;700;800&amp;family=Inter:wght@400;500;600&amp;display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-surface text-on-surface font-body min-h-screen flex flex-col">
    <%-include('../partials/header')%>

    <main class="flex-grow pt-[72px]">
      <!-- Dashboard Header -->
      <section
        class="px-10 py-10 flex flex-col md:flex-row justify-between items-end md:items-center gap-6"
      >
        <div class="space-y-1">
          <p
            class="font-label uppercase tracking-widest text-[10px] text-primary opacity-80"
          >
            Gestión de inventario
          </p>
          <h1
            class="font-headline font-extrabold text-5xl tracking-tight text-on-surface"
          >
            <%= title%>
          </h1>
        </div>
        <a
          href="/games/create"
          class="primary-gradient text-on-primary-fixed font-label font-bold uppercase tracking-widest text-[10px] px-8 py-4 rounded-sm flex items-center gap-3 active:scale-95 duration-150 ease-in-out"
        >
          <span
            class="material-symbols-outlined"
            style="font-variation-settings: 'wght' 600"
            >add</span
          >
          Agregar nuevo juego
        </a>
      </section>

       

      <!-- Game Grid: Intentional Asymmetry -->
      <section class="px-10 py-12">
        <ul
          class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-x-6 gap-y-10"
        >
          <% games.forEach(game => { %>
          <li>
            <a class="group flex flex-col" href="/games/<%= game.id%>">
              <div
                class="relative aspect-[3/4] mb-4 overflow-hidden rounded-sm bg-surface-container"
              >
                <img
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 opacity-80 group-hover:opacity-100"
                  data-alt="Cinematic close-up of a futuristic high-tech soldier helmet with blue glowing visors and dark matte mechanical textures"
                  src="<%= game.image_url ? game.image_url : 'https://static.vecteezy.com/system/resources/previews/005/720/408/non_2x/crossed-image-icon-picture-not-available-delete-picture-symbol-free-vector.jpg' %>"
                />
                <!--  -->
                <div
                  class="absolute top-0 left-0 w-0.5 h-full bg-tertiary"
                ></div>
              </div>

              <div class="flex justify-between items-start">
                <div>
                  <h3
                    class="font-headline font-bold text-lg text-on-surface leading-tight"
                  >
                    <%=game.name%>
                  </h3>
                  <p
                    class="font-label uppercase tracking-widest text-[9px] text-outline mt-1"
                  >
                    <%=game.description%>
                  </p>
                </div>
              </div></a
            >
          </li>
          <%})%>
        </ul>
      </section>
    </main>

    <%-include('../partials/footer')%>
  </body>
</html>
