<nav class="fixed top-0 w-full z-50 bg-[#1C1B1B] text-[#BAC3FF]">
  <div class="flex justify-between items-center px-6 md:px-10 py-4">
    <!-- LOGO -->
    <div class="text-xl font-black tracking-tighter font-headline">
      ARCHIVO TÁCTICO
    </div>

    <!-- DESKTOP MENU -->
    <div
      class="hidden md:flex items-center space-x-8 text-[10px] font-label uppercase tracking-widest"
    >
      <a
        href="/"
        class="<%= currentPath === '/' ? 'text-[#BAC3FF] border-b-2 border-[#3F51B5]' : 'text-slate-500 hover:text-slate-300' %> pb-1"
      >
        Inicio
      </a>

      <a
        href="/games"
        class="<%= currentPath.startsWith('/games') ? 'text-[#BAC3FF] border-b-2 border-[#3F51B5]' : 'text-slate-500 hover:text-slate-300' %> pb-1"
      >
        Juegos
      </a>

      <a
        href="/genres"
        class="<%= currentPath.startsWith('/genres') ? 'text-[#BAC3FF] border-b-2 border-[#3F51B5]' : 'text-slate-500 hover:text-slate-300' %> pb-1"
      >
        Géneros
      </a>
    </div>

    <!-- RIGHT SIDE -->
    <div class="flex md:hidden items-center gap-3">
      <!-- HAMBURGER -->
      <button
        id="menu-btn"
        class="material-symbols-outlined p-2 hover:bg-[#2A2A2A] active:scale-95"
      >
        menu
      </button>
    </div>
  </div>

  <!-- MOBILE MENU -->
  <div
    id="mobile-menu"
    class="hidden md:hidden flex flex-col px-6 pb-4 space-y-4 transition-all duration-300"
  >
    <a
      href="/"
      class="<%= currentPath === '/' ? 'text-[#BAC3FF]' : 'text-slate-500' %>"
    >
      Inicio
    </a>

    <a
      href="/games"
      class="<%= currentPath.startsWith('/games') ? 'text-[#BAC3FF]' : 'text-slate-500' %>"
    >
      Juegos
    </a>

    <a
      href="/genres"
      class="<%= currentPath.startsWith('/genres') ? 'text-[#BAC3FF]' : 'text-slate-500' %>"
    >
      Géneros
    </a>
  </div>
</nav>

<script>
  const btn = document.getElementById("menu-btn");
  const menu = document.getElementById("mobile-menu");

  btn.addEventListener("click", () => {
    menu.classList.toggle("hidden");
  });
</script>

<!-- ARCHIVO TÁCTICO -->
