<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title%></title>
    <link rel="stylesheet" href="/styles/output.css" />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;700;800&amp;family=Inter:wght@400;500;600&amp;display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-surface text-on-surface font-body min-h-screen flex flex-col">
    <%- include('../partials/header') %>
    <main class="flex-grow flex flex-col items-center px-6 py-12 md:py-24">
      <div class="w-full max-w-5xl grid grid-cols-1 md:grid-cols-12 gap-8">
        <!-- Side Metadata (Asymmetric Layout) -->
        <div class="md:col-span-4 flex flex-col gap-6 order-2 md:order-1">
          <div class="bg-surface-container-low p-8 relative overflow-hidden">
            <div class="absolute top-0 left-0 w-1 h-full bg-primary"></div>
            <h2
              class="font-headline font-bold text-xs uppercase tracking-[0.2em] text-primary mb-4"
            >
              DETALLES DEL GÉNERO
            </h2>
            <p
              class="text-on-surface-variant text-sm leading-relaxed font-body"
            >
              Pon el nombre y la descripción del género para mantener un
              catálogo de juegos claro y organizado.
            </p>
          </div>
        </div>
        <!-- Main Form Content -->
        <div class="md:col-span-8 flex flex-col order-1 md:order-2">
          <div class="mb-10">
            <h1
              class="font-headline font-extrabold text-4xl md:text-5xl tracking-tighter text-on-surface"
            >
              <%= title%>
            </h1>
          </div>
          <form method="POST" class="space-y-8">
            <div class="space-y-2">
              <label
                class="font-label text-[10px] uppercase tracking-[0.3em] text-outline ml-1"
                for="genre_name"
                >Nombre del Género</label
              >
              <input
                class="w-full bg-surface-container-highest border-none focus:ring-1 focus:ring-primary-container p-4 font-headline font-bold text-xl tracking-tight text-on-surface rounded-none transition-all"
                name="name"
                value="<%= genre ? genre.name : '' %>"
                required
              />
            </div>
            <div class="space-y-2">
              <label
                class="font-label text-[10px] uppercase tracking-[0.3em] text-outline ml-1"
                for="genre_description"
                >Descripción del Género</label
              >
              <textarea
                class="w-full bg-surface-container-highest border-none focus:ring-1 focus:ring-primary-container p-4 font-body text-sm leading-relaxed text-on-surface-variant rounded-none transition-all"
                name="description"
                rows="6"
              >
<%= genre ? genre.description : '' %></textarea
              >
            </div>
            <div
              class="flex flex-col md:flex-row gap-4 pt-4 items-center justify-between"
            >
              <div class="flex items-center gap-4 w-full md:w-auto">
                <button
                  class="bg-gradient-to-br from-primary to-primary-container text-on-primary-fixed px-10 py-4 font-headline font-extrabold uppercase tracking-widest text-xs rounded-sm hover:brightness-110 active:scale-95 transition-all w-full md:w-auto shadow-[0_10px_30px_rgba(8,33,138,0.2)]"
                  type="submit"
                >
                  Guardar
                </button>
                <a
                  href="/genres"
                  class="bg-transparent border border-outline-variant/30 text-on-surface px-8 py-4 font-label font-bold uppercase tracking-widest text-[10px] rounded-sm hover:bg-surface-container-highest transition-all w-full md:w-auto"
                >
                  Cancel
                </a>
              </div>
            </div>
          </form>
        </div>
      </div>
    </main>
    <%- include('../partials/footer') %>
  </body>
</html>
