<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title%></title>
    <link rel="stylesheet" href="/styles/output.css" />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;700;800&amp;family=Inter:wght@400;500;600&amp;display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-surface text-on-surface font-body min-h-screen flex flex-col">
    <%- include('../partials/header') %>
    <main class="flex-grow w-full max-w-7xl pt-20 mx-auto px-10 py-12">
      <!-- Genre Header Section -->
      <section class="mb-16 grid grid-cols-1 lg:grid-cols-12 gap-8 items-end">
        <div class="lg:col-span-8">
          <h1
            class="font-headline font-extrabold text-6xl md:text-8xl tracking-tighter text-on-background mb-6"
          >
            <%= genre.name %>
          </h1>
          <p
            class="font-body text-on-surface-variant max-w-xl text-lg leading-relaxed border-l-2 border-surface-bright pl-6"
          >
            <%= genre.description %>
          </p>
        </div>
        <div
          class="lg:col-span-4 cursor-pointer flex flex-col gap-3 md:items-end"
        >
          <a
            href="/genres/<%= genre.id %>/update"
            class="w-full md:w-auto px-8 py-3 bg-surface-container-highest hover:bg-surface-bright text-on-surface font-label uppercase tracking-widest text-xs transition-all duration-300 flex items-center justify-center gap-2 rounded-sm active:scale-95"
          >
            <span class="material-symbols-outlined text-sm" data-icon="edit"
              >edit</span
            >
            Editar Género
          </a>
          <form action="/genres/<%= genre.id%>/delete" method="POST">
            <button
              class="w-full md:w-auto px-8 py-3 bg-tertiary-container hover:opacity-90 text-on-tertiary-container font-label uppercase tracking-widest text-xs transition-all duration-300 flex items-center justify-center gap-2 rounded-sm active:scale-95"
            >
              <span class="material-symbols-outlined text-sm" data-icon="delete"
                >delete</span
              >
              Eliminar Género
            </button>
          </form>
        </div>
      </section>
    </main>
    <%- include('../partials/footer') %>
  </body>
</html>
